generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Only operational data selected for PostgreSQL lives here. Settings,
// provider connections, provider nodes, proxy pools, combos, request details,
// and most kv stay local.
model ApiKey {
  id        String  @id
  key       String  @unique
  name      String?
  owner     String?
  machineId String?
  isActive  Int?    @default(1)
  createdAt String

  @@index([key], map: "idx_ak_key")
  @@map("apiKeys")
}

model OwnerUser {
  email     String @id
  budgetUsd Float  @default(0)
  isActive  Int?   @default(1)
  createdAt String
  updatedAt String

  @@map("ownerUsers")
}

// Incrementally-maintained lifetime spend per owner — budget checks read this
// single row instead of SUM-ing usageHistory per request. Created MANUALLY
// (migrate history is broken): apply prisma/manual/add-owner-spend.sql via
// `prisma db execute`, then `prisma generate`. Until then the code falls back
// to the SUM path automatically.
model OwnerSpend {
  owner        String @id
  spentUsd     Float  @default(0)
  requestCount Int    @default(0)
  updatedAt    String

  @@map("ownerSpend")
}

model UsageHistory {
  id               Int     @id @default(autoincrement())
  timestamp        String
  provider         String?
  model            String?
  connectionId     String?
  apiKey           String?
  owner            String?
  endpoint         String?
  promptTokens     Int?    @default(0)
  completionTokens Int?    @default(0)
  cost             Float?  @default(0)
  status           String?
  tokens           String?
  meta             String?

  @@index([timestamp], map: "idx_uh_ts")
  @@index([provider], map: "idx_uh_provider")
  @@index([model], map: "idx_uh_model")
  @@index([connectionId], map: "idx_uh_conn")
  @@index([owner], map: "idx_uh_owner")
  @@map("usageHistory")
}

model UsageDaily {
  dateKey String @id
  data    String

  @@map("usageDaily")
}

model EnabledModel {
  providerAlias String
  modelId       String
  createdAt     String

  @@id([providerAlias, modelId])
  @@index([providerAlias], map: "idx_em_provider")
  @@map("enabledModels")
}

model EnabledProvider {
  providerAlias String @id
  createdAt     String

  @@map("enabledProviders")
}

model Pricing {
  providerAlias String
  modelId       String
  input         Float?
  output        Float?
  cached        Float?
  reasoning     Float?
  cacheCreation Float? @map("cache_creation")
  updatedAt     String

  @@id([providerAlias, modelId])
  @@index([providerAlias], map: "idx_pricing_provider")
  @@map("pricing")
}

model Voucher {
  id         String  @id
  code       String  @unique
  amountUsd  Float
  status     String  @default("active")
  redeemedBy String?
  redeemedAt String?
  note       String?
  createdAt  String
  updatedAt  String

  @@index([status], map: "idx_voucher_status")
  @@map("vouchers")
}
